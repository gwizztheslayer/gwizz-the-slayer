'use client';
import { useState, useRef, useEffect } from 'react';
import { Play, Pause, Volume2, SkipForward, SkipBack } from 'lucide-react';
import { motion } from 'framer-motion';

export default function AudioPlayer() {
  const [isPlaying, setIsPlaying] = useState(false);
  const audioRef = useRef(null);

  const togglePlay = () => {
    if (isPlaying) {
      audioRef.current.pause();
    } else {
      audioRef.current.play();
    }
    setIsPlaying(!isPlaying);
  };

  return (
    <motion.div 
      initial={{ y: 100 }}
      animate={{ y: 0 }}
      transition={{ type: 'spring', stiffness: 100, damping: 20 }}
      className="fixed bottom-0 left-0 right-0 h-24 bg-black/90 backdrop-blur-md border-t border-cyan-500/50 z-50 flex items-center px-6 md:px-12 justify-between"
    >
      {/* Hidden Audio Element - Add actual audio src when ready */}
      <audio ref={audioRef} src="/audio/demons-dont-sleep-snippet.mp3" loop />

      {/* Track Info */}
      <div className="flex items-center gap-4 w-1/3">
        <div className="w-12 h-12 bg-gray-900 border border-cyan-500/30 shadow-[0_0_15px_rgba(6,182,212,0.3)] flex items-center justify-center relative overflow-hidden group">
            <div className="absolute inset-0 bg-cyan-500/20 group-hover:bg-cyan-500/40 transition-colors"></div>
        </div>
        <div className="hidden sm:block">
          <h4 className="text-white font-bold uppercase tracking-wider text-sm">Demons Don't Sleep</h4>
          <p className="text-cyan-400 text-xs font-mono tracking-widest">Gwizz The Slayer</p>
        </div>
      </div>

      {/* Controls */}
      <div className="flex items-center justify-center gap-6 w-1/3">
        <button className="text-gray-400 hover:text-white transition-colors">
          <SkipBack size={20} />
        </button>
        <button 
          onClick={togglePlay}
          className="w-12 h-12 rounded-full bg-cyan-500 text-black flex items-center justify-center hover:bg-cyan-400 hover:scale-105 transition-all shadow-[0_0_20px_rgba(6,182,212,0.5)]"
        >
          {isPlaying ? <Pause size={24} fill="currentColor" /> : <Play size={24} fill="currentColor" className="ml-1" />}
        </button>
        <button className="text-gray-400 hover:text-white transition-colors">
          <SkipForward size={20} />
        </button>
      </div>

      {/* Volume / Extra */}
      <div className="flex justify-end w-1/3 text-gray-400 hidden sm:flex">
        <Volume2 size={20} className="hover:text-cyan-400 transition-colors cursor-pointer" />
      </div>
    </motion.div>
  );
}
